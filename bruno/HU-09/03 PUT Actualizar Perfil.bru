meta {
  name: 03 PUT Actualizar Perfil
  type: http
  seq: 3
}

put {
  url: http://localhost:8080/api/clientes/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "telefono": "999111222",
    "direccion": "Av. Portal 456"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}
