meta {
  name: 06 Obtener Cliente Por ID
  type: http
  seq: 6
}

get {
  url: http://localhost:8080/api/clientes/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.idLicencia: isNotEmpty
  res.body.data.numeroLicencia: isNotEmpty
  res.body.data.categoriaLicencia: isNotEmpty
  res.body.data.fechaVencimientoLicencia: isNotEmpty
}
