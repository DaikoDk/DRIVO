meta {
  name: 02 GET Perfil Me
  type: http
  seq: 2
}

get {
  url: http://localhost:8080/api/clientes/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.nombre: eq Portal
  res.body.data.email: eq portal@email.com
}
