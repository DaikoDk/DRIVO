meta {
  name: 09 Cancelar Reserva Propia
  type: http
  seq: 9
}

patch {
  url: http://localhost:8080/api/reservas/{{reservaId}}/cancelar-desde-portal
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.estado: eq Cancelada
}
