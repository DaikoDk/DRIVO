meta {
  name: 02 Crear Reparacion
  type: http
  seq: 2
}

post {
  url: http://localhost:8080/api/reparaciones
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "idReserva": 1,
    "idAuto": 1,
    "idCatalogoReparacion": 1,
    "descripcion": "Rallon en puerta",
    "costo": 200.00,
    "responsable": "Cliente",
    "usuarioReporte": "admin@drivo.com"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.estado: eq Pendiente
}
