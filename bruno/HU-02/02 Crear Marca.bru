meta {
  name: 02 Crear Marca
  type: http
  seq: 2
}

post {
  url: http://localhost:8080/api/marcas
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "nombre": "Kia"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.nombre: eq Kia
}
