# ============================================================
# DRIVO Rent-a-Car - Variables de Entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores a tu entorno
# cp .env.example .env
# ============================================================

# Puerto del servidor (default: 8080)
SERVER_PORT=8080

# Base de datos SQL Server
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=BD_RentCar;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=TuPasswordAqui

# JWT (cambiar en produccion)
JWT_SECRET=drivo-alquilerauto-jwt-secret-key-2026-must-be-256-bits-minimum

# ============================================================
# NOTAS:
# - Cada desarrollador usa sus propias credenciales
# - El .env NO se sube al repositorio (esta en .gitignore)
# - El application.yaml tiene valores por defecto para 
#   desarrollo local, solo necesitas .env si tus credenciales
#   difieren de las default
# ============================================================
