meta {
  name: 05 Cambiar Estado Completada
  type: http
  seq: 5
}

patch {
  url: http://localhost:8080/api/reparaciones/1/estado
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "estado": "Completada"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.estado: eq Completada
}
