meta {
  name: 05 Obtener Auto Por ID
  type: http
  seq: 5
}

get {
  url: http://localhost:8080/api/autos/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.marca: isNotEmpty
  res.body.data.modelo: isNotEmpty
}
