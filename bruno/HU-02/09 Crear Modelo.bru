meta {
  name: 09 Crear Modelo
  type: http
  seq: 9
}

post {
  url: http://localhost:8080/api/modelos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "idMarca": 1,
    "nombre": "Corolla 2026"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.nombre: eq Corolla 2026
}
