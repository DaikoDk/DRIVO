meta {
  name: 12 Crear Configuracion
  type: http
  seq: 12
}

post {
  url: http://localhost:8080/api/configuraciones
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "clave": "TestConfig",
    "valor": "42",
    "descripcion": "Config de prueba",
    "tipo": "entero"
  }
}

assert {
  res.status: eq 200
  res.body.success: eq true
}
