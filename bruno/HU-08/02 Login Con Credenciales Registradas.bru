meta {
  name: 02 Login Con Credenciales Registradas
  type: http
  seq: 2
}

post {
  url: http://localhost:8080/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "correo": "pedro@email.com",
    "clave": "pedro123"
  }
}

assert {
  res.status: eq 200
  res.body.token: isNotEmpty
  res.body.rol: eq CLIENTE
}
