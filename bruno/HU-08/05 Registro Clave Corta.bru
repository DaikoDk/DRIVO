meta {
  name: 05 Registro Clave Corta
  type: http
  seq: 5
}

post {
  url: http://localhost:8080/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "nombre": "Test",
    "apellidoPaterno": "Corto",
