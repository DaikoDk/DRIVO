meta {
  name: 09 Guardar ID Segunda Reserva
  type: http
  seq: 9
}

get {
  url: http://localhost:8080/api/reservas
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:post-response {
  reservaId2: res.body.data[0].idReserva
}

assert {
  res.status: eq 200
  res.body.success: eq true
}
