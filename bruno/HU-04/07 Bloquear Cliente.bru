meta {
  name: 07 Bloquear Cliente
  type: http
  seq: 7
}

patch {
  url: http://localhost:8080/api/clientes/2/bloquear
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.bloqueado: eq true
  res.body.data.estado: eq inactivo
}
